#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# آدرس سایت با / در انتها — مثال: https://panel.example.com/
app.baseURL = 'https://yourdomain.com/'
app.forceGlobalSecureRequests = true
app.defaultLocale = fa

#--------------------------------------------------------------------
# DATABASE (MySQL — cPanel)
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = your_cpanel_db_name
database.default.username = your_cpanel_db_user
database.default.password = your_cpanel_db_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# تولید کلید: php spark key:generate
encryption.key = hex2bin:CHANGE_ME_RUN_spark_key_generate

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
