# BizPanel — cPanel when Document Root = project root (not public/)
Options -Indexes

<Files ".env">
    Require all denied
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to application internals
    RewriteRule ^(app|vendor|writable|tests|system)(/|$) - [F,L]

    # Static files and routes live under public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
